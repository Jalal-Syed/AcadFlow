{
  "name": "AcadFlow",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "main": "electron/main.js",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "lint": "eslint . --ext ts,tsx --report-unused-disable-directives --max-warnings 0",
    "format": "prettier --write \"src/**/*.{ts,tsx,css}\"",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:e2e": "playwright test",
    "cap:sync": "npm run build && npx cap sync android",
    "cap:open": "npx cap open android",
    "electron:dev": "cross-env NODE_ENV=development electron .",
    "electron:build": "cross-env ELECTRON=true pnpm build && electron-builder",
    "electron:build:win": "cross-env ELECTRON=true pnpm build && electron-builder --win",
    "electron:build:linux": "cross-env ELECTRON=true pnpm build && electron-builder --linux",
    "electron:build:mac": "cross-env ELECTRON=true pnpm build && electron-builder --mac"
  },
  "dependencies": {
    "@capacitor/android": "^6.2.1",
    "@capacitor/app": "^6.0.3",
    "@capacitor/core": "^6.2.1",
    "@capacitor/haptics": "^6.0.3",
    "@capacitor/local-notifications": "^6.1.3",
    "@capacitor/preferences": "^6.0.4",
    "@capacitor/splash-screen": "^6.0.4",
    "@capacitor/status-bar": "^6.0.3",
    "@hookform/resolvers": "^3.10.0",
    "@supabase/supabase-js": "^2.103.3",
    "clsx": "^2.1.1",
    "dayjs": "^1.11.20",
    "dexie": "^3.2.7",
    "dexie-react-hooks": "^1.1.7",
    "file-saver": "^2.0.5",
    "framer-motion": "^11.18.2",
    "jspdf": "^2.5.2",
    "jspdf-autotable": "^3.8.4",
    "lucide-react": "^0.363.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-hook-form": "^7.72.1",
    "react-router-dom": "^6.30.3",
    "recharts": "^2.15.4",
    "tailwind-merge": "^2.6.1",
    "xlsx": "^0.18.5",
    "zod": "^3.25.76",
    "zustand": "^4.5.7"
  },
  "devDependencies": {
    "@capacitor/cli": "^6.2.1",
    "@playwright/test": "^1.59.1",
    "@types/file-saver": "^2.0.7",
    "@types/react": "^18.3.28",
    "@types/react-dom": "^18.3.7",
    "@typescript-eslint/eslint-plugin": "^7.18.0",
    "@typescript-eslint/parser": "^7.18.0",
    "@vitejs/plugin-react": "^4.7.0",
    "autoprefixer": "^10.5.0",
    "cross-env": "^7.0.3",
    "electron": "^30.5.1",
    "electron-builder": "^24.13.3",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.26",
    "husky": "^9.1.7",
    "lint-staged": "^15.5.2",
    "postcss": "^8.5.10",
    "prettier": "^3.8.3",
    "tailwindcss": "^3.4.19",
    "typescript": "^5.9.3",
    "vite": "^5.4.21",
    "vite-plugin-pwa": "^0.19.8",
    "vitest": "^1.6.1",
    "workbox-window": "^7.4.0"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "prettier --write"
    ],
    "*.{css,md,json}": "prettier --write"
  },
  "build": {
    "appId": "com.acadflow.app",
    "productName": "AcadFlow",
    "copyright": "Copyright © 2025 AcadFlow",
    "publish": {
      "provider": "github",
      "owner": "Jalal-Syed",
      "repo": "AcadFlow"
    },
    "directories": {
      "output": "release-builds",
      "buildResources": "electron/assets"
    },
    "files": [
      "dist/**/*",
      "electron/main.js",
      "electron/preload.js",
      "electron/scraper-bridge.js",
      "electron/package.json",
      "package.json"
    ],
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "electron/assets/icon.png",
      "category": "Education"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "electron/assets/icon.icns",
      "category": "public.app-category.education"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true
    },
    "dmg": {
      "title": "Install AcadFlow"
    }
  }
}
